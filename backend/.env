# -----------------------------
# 🚀 SERVER CONFIG
# -----------------------------
PORT=5000
NODE_ENV=development

# -----------------------------
# 🛢️ DATABASE (MongoDB)
# -----------------------------
MONGO_URI=mongodb://localhost:27017/exam_proctoring

# -----------------------------
# 🔐 AUTHENTICATION
# -----------------------------
JWT_SECRET=your_super_secret_jwt_key
JWT_EXPIRES_IN=7d

# -----------------------------
# ⚡ SOCKET CONFIG (optional scaling)
# -----------------------------
SOCKET_CORS_ORIGIN=*

# -----------------------------
# 🧠 ML / AI CONFIG (future tuning)
# -----------------------------
ML_DECAY_FACTOR=0.98
ML_SYNERGY_COEFFICIENT=0.2
ML_BIAS=-1.15

# -----------------------------
# 📸 UPLOAD SYSTEM
# -----------------------------
MAX_FILE_SIZE=5242880   # 5MB
UPLOAD_DIR=uploads

# -----------------------------
# 🧾 AUDIT LOGGING
# -----------------------------
ENABLE_AUDIT_LOGS=true

# -----------------------------
# 🔥 RATE LIMITING
# -----------------------------
RATE_LIMIT_WINDOW=900000   # 15 min
RATE_LIMIT_MAX=100

# -----------------------------
# 🌐 FRONTEND (CORS)
# -----------------------------
CLIENT_URL=http://localhost:5173

# -----------------------------
# 🐳 DOCKER / DEPLOYMENT
# -----------------------------
HOST=0.0.0.0

# -----------------------------
# 📊 OPTIONAL (future extensions)
# -----------------------------
REDIS_URL=redis://localhost:6379
ENABLE_REDIS=false

# -----------------------------
# 📡 MONITORING (optional)
# -----------------------------
LOG_LEVEL=info
ENABLE_LOGS=true